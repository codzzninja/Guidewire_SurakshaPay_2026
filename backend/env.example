# Copy to backend/.env
#
# Docker Compose: this file must exist as backend/.env so the backend container loads
# Razorpay + SMS keys. From backend/:  copy env.example .env  then edit.

SECRET_KEY=replace-with-long-random-string
DATABASE_URL=sqlite:///./surakshapay.db

# Celery broker + result backend (local: localhost; Docker Compose: redis://redis:6379/0)
REDIS_URL=redis://localhost:6379/0

# Server-side cache TTL for OpenWeather/WAQI/RSS bundle (seconds). Default 300.
# ENVIRONMENT_CACHE_TTL_SECONDS=300

# Set true only when developing without weather/WAQI/model (full mock stack)
ALLOW_MOCKS=false
# Demo/hackathon: enables POST /monitoring/evaluate { "demo_weather_integrity_mismatch": true } to inject
# contradictory rain flags vs metrics (weather fraud edge case) without turning on full ALLOW_MOCKS.
DEMO_WEATHER_EDGE_CASE=false

# OpenWeatherMap (free): https://openweathermap.org/api
OPENWEATHER_API_KEY=<openweather_api_key>

# WAQI (free token): https://aqicn.org/data-platform/token/
WAQI_API_TOKEN=<waqi_api_token>


# Razorpay TEST keys (optional at first). When empty, payouts are simulated if:
#   RAZORPAY_OPTIONAL=true (default). Get keys: Razorpay Dashboard → Settings → API Keys (Test mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: Razorpay Dashboard → Webhooks → signing secret (for POST /webhooks/razorpay)
RAZORPAY_WEBHOOK_SECRET=
# Default true: allow running without Razorpay; set false when you require real Test Mode orders
RAZORPAY_OPTIONAL=true
# Claim payout mode for evaluate pipeline:
# - upi_simulator (default): fake success ref for hackathon/demo
PAYOUT_PROVIDER=upi_simulator
# Compliance controls
# DPDP-style explicit user consent is enforced at registration.
# Demo KYC tail (PAN last 4 alnum or Aadhaar last 4 digits) is captured at registration; premium + payouts require kyc_status=verified.
# Keep these OFF for demo now; turn ON when you have production-grade data + policy setup.
ENFORCE_LOCKOUT=false
ENFORCE_MIN_ACTIVE_DAYS=false
MIN_ACTIVE_DAYS_FOR_PAYOUT=90
# Social Security proxy gate uses min active workdays in last 365 when ENFORCE_MIN_ACTIVE_DAYS=true.

# Stripe Test Mode (sk_test_...) — real hosted Checkout, no real money. Use if Razorpay is unreachable.
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Must match where the worker app loads after payment (Stripe redirects here with ?stripe_session_id=...)
FRONTEND_BASE_URL=http://localhost:5173

# --- SMS after successful payment (optional) — sends to user's registered phone ---
# Leave SMS_PROVIDER empty to disable. India numbers: 10 digits or +91...
#
# Twilio: https://www.twilio.com/docs/sms (trial = only verified numbers)
# SMS_PROVIDER=twilio
# SMS_TWILIO_ACCOUNT_SID=
# SMS_TWILIO_AUTH_TOKEN=
# SMS_TWILIO_FROM=+1xxxxxxxxxx
#
# Fast2SMS (India): https://www.fast2sms.com/ — use approved DLT template text if required
SMS_PROVIDER=fast2sms
SMS_FAST2SMS_API_KEY=<fast2sms_api_key>
SMS_FAST2SMS_SENDER_ID=<your 6-letter sender>
SMS_FAST2SMS_DLT_MESSAGE_ID=<numeric template ID>
# Real public RSS (default: ReliefWeb India)
GOVERNMENT_RSS_URL=https://reliefweb.int/updates/rss.xml?search=country:India

CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost

# Phase 3 insurer dashboard (/insurer UI) — optional shared secret
# ADMIN_ANALYTICS_TOKEN=
# How many work zones to sample for multi-market weather (default 8)
# INSURER_WEATHER_MAX_MARKETS=8
